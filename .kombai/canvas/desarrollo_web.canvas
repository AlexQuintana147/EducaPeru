      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --font-display: 'Instrument Sans', sans-serif;\n    --font-body: 'Inter', sans-serif;\n  }\n\n  body {\n    background-color: #000000;\n    color: #ffffff;\n    font-family: var(--font-body);\n    margin: 0;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-display { font-family: var(--font-display); }\n\n  /* Blueprint Grid Pattern */\n  .grid-pattern {\n    background-image: \n      linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);\n    background-size: 80px 80px;\n  }\n\n  /* Dashed Divider */\n  .border-blueprint {\n    border-style: dashed;\n    border-color: rgba(255, 255, 255, 0.1);\n  }\n\n  /* Custom Glow for Button */\n  .btn-glow:hover {\n    box-shadow: 0 0 20px rgba(255, 255, 255, 0.3);\n  }\n\n  /* Horizontal Line for Process */\n  .process-line {\n    position: absolute;\n    top: 50%;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background-image: linear-gradient(to right, rgba(255, 255, 255, 0.2) 50%, transparent 50%);\n    background-size: 20px 1px;\n    z-index: 0;\n  }\n\n  /* Animation for Ink CTA */\n  .cta-video-container {\n    mask-image: radial-gradient(circle at center, black 0%, transparent 80%);\n  }\n</style>\n\n<div class=\"relative w-full min-h-screen grid-pattern\" data-kid=\"1\">\n  \n  \n  <nav class=\"sticky top-0 z-50 flex items-center justify-between px-10 py-6 border-b border-blueprint bg-black/80 backdrop-blur-md\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-8 h-8 border border-white flex items-center justify-center font-bold text-sm\" data-kid=\"4\">EP</div>\n      <span class=\"font-display font-bold tracking-tighter text-lg uppercase\" data-kid=\"5\">EducaPerú</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-10 text-xs font-medium uppercase tracking-[0.2em] text-white/60\" data-kid=\"6\">\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"7\">Proceso</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"8\">Servicios</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"9\">Proyectos</a>\n    </div>\n    <a href=\"#contacto\" class=\"px-6 py-2 border border-blueprint text-[10px] font-bold uppercase tracking-widest hover:bg-white hover:text-black transition-all\" data-kid=\"10\">\n      Cotizar Proyecto\n    </a>\n  </nav>\n\n  \n  <section class=\"relative pt-32 pb-48 px-10\" data-kid=\"11\">\n    <div class=\"max-w-5xl mx-auto text-center\" data-kid=\"12\">\n      <div class=\"inline-block px-4 py-1 border border-blueprint rounded-full text-[10px] font-bold uppercase tracking-[0.3em] text-white/40 mb-12\" data-kid=\"13\">\n        Arquitectura Digital de Alto Impacto\n      </div>\n      <h1 class=\"font-display text-7xl md:text-[110px] font-extrabold leading-[0.9] tracking-tighter mb-8\" data-kid=\"14\">\n        DISEÑO WEB.<br data-kid=\"15\">HECHO SIMPLE.\n      </h1>\n      <p class=\"text-white/40 text-lg md:text-xl max-w-2xl mx-auto mb-16 font-light leading-relaxed\" data-kid=\"16\">\n        Eliminamos la fricción técnica para que puedas concentrarte en lo que importa: hacer crecer tu negocio con una web que proyecta confianza y calidad.\n      </p>\n      <div class=\"flex flex-col sm:flex-row items-center justify-center gap-6\" data-kid=\"17\">\n        <a href=\"#contacto\" class=\"px-10 py-5 bg-white text-black font-display font-bold text-sm uppercase tracking-widest btn-glow transition-all\" data-kid=\"18\">\n          Empezar Ahora\n        </a>\n        <a href=\"#proceso\" class=\"px-10 py-5 border border-blueprint text-white font-display font-bold text-sm uppercase tracking-widest hover:bg-white/5 transition-all\" data-kid=\"19\">\n          Ver Metodología\n        </a>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-10 border-t border-blueprint\" data-kid=\"20\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"21\">\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-y-20 md:gap-x-20\" data-kid=\"22\">\n        \n        <div class=\"group\" data-kid=\"23\">\n          <div class=\"mb-10 text-white/20 transition-colors group-hover:text-white\" data-kid=\"24\">\n            <i class=\"ti ti-clock text-6xl font-thin\" data-kid=\"25\"></i>\n          </div>\n          <h3 class=\"font-display text-2xl font-bold mb-4\" data-kid=\"26\">Presencia 24/7</h3>\n          <p class=\"text-white/40 leading-relaxed font-light\" data-kid=\"27\">\n            Tu negocio nunca duerme. Construimos plataformas robustas que funcionan sin interrupciones, captando clientes mientras tú descansas.\n          </p>\n        </div>\n        \n        <div class=\"group\" data-kid=\"28\">\n          <div class=\"mb-10 text-white/20 transition-colors group-hover:text-white\" data-kid=\"29\">\n            <i class=\"ti ti-briefcase text-6xl font-thin\" data-kid=\"30\"></i>\n          </div>\n          <h3 class=\"font-display text-2xl font-bold mb-4\" data-kid=\"31\">Imagen Profesional</h3>\n          <p class=\"text-white/40 leading-relaxed font-light\" data-kid=\"32\">\n            La primera impresión es la que cuenta. Diseñamos estéticas que elevan el valor percibido de tu marca al nivel de las grandes empresas.\n          </p>\n        </div>\n        \n        <div class=\"group\" data-kid=\"33\">\n          <div class=\"mb-10 text-white/20 transition-colors group-hover:text-white\" data-kid=\"34\">\n            <i class=\"ti ti-users text-6xl font-thin\" data-kid=\"35\"></i>\n          </div>\n          <h3 class=\"font-display text-2xl font-bold mb-4\" data-kid=\"36\">Más Contactos</h3>\n          <p class=\"text-white/40 leading-relaxed font-light\" data-kid=\"37\">\n            No solo es diseño, es psicología. Optimizamos cada sección para guiar al visitante hacia la acción, aumentando tus prospectos reales.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"proceso\" class=\"py-48 px-10 border-t border-blueprint relative overflow-hidden\" data-kid=\"38\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"39\">\n      <div class=\"text-center mb-32\" data-kid=\"40\">\n        <h2 class=\"font-display text-5xl font-extrabold tracking-tighter mb-4\" data-kid=\"41\">NUESTRA HOJA DE RUTA</h2>\n        <p class=\"text-white/40 uppercase tracking-[0.2em] text-xs\" data-kid=\"42\">Cuatro fases hacia tu éxito digital</p>\n      </div>\n\n      <div class=\"relative\" data-kid=\"43\">\n        <div class=\"process-line hidden lg:block\" data-kid=\"44\"></div>\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-0 relative z-10\" data-kid=\"45\">\n          \n          \n          <div class=\"flex flex-col items-center lg:items-start lg:px-10\" data-kid=\"46\">\n            <div class=\"font-display text-8xl font-extrabold text-white/5 mb-6 hover:text-white transition-colors cursor-default\" data-kid=\"47\">01</div>\n            <h4 class=\"font-display text-lg font-bold mb-3\" data-kid=\"48\">DESCUBRIMIENTO</h4>\n            <p class=\"text-xs text-white/40 font-light leading-relaxed max-w-[200px]\" data-kid=\"49\">Auditoría de tu negocio y definición de objetivos claros.</p>\n          </div>\n\n          \n          <div class=\"flex flex-col items-center lg:items-start lg:px-10\" data-kid=\"50\">\n            <div class=\"font-display text-8xl font-extrabold text-white/5 mb-6 hover:text-white transition-colors cursor-default\" data-kid=\"51\">02</div>\n            <h4 class=\"font-display text-lg font-bold mb-3\" data-kid=\"52\">PROPUESTA</h4>\n            <p class=\"text-xs text-white/40 font-light leading-relaxed max-w-[200px]\" data-kid=\"53\">Diseño visual y arquitectura del sitio bajo tu aprobación.</p>\n          </div>\n\n          \n          <div class=\"flex flex-col items-center lg:items-start lg:px-10\" data-kid=\"54\">\n            <div class=\"font-display text-8xl font-extrabold text-white/5 mb-6 hover:text-white transition-colors cursor-default\" data-kid=\"55\">03</div>\n            <h4 class=\"font-display text-lg font-bold mb-3\" data-kid=\"56\">DESARROLLO</h4>\n            <p class=\"text-xs text-white/40 font-light leading-relaxed max-w-[200px]\" data-kid=\"57\">Construcción con tecnologías modernas y optimización SEO.</p>\n          </div>\n\n          \n          <div class=\"flex flex-col items-center lg:items-start lg:px-10\" data-kid=\"58\">\n            <div class=\"font-display text-8xl font-extrabold text-white/5 mb-6 hover:text-white transition-colors cursor-default\" data-kid=\"59\">04</div>\n            <h4 class=\"font-display text-lg font-bold mb-3\" data-kid=\"60\">LANZAMIENTO</h4>\n            <p class=\"text-xs text-white/40 font-light leading-relaxed max-w-[200px]\" data-kid=\"61\">Pruebas finales, puesta en marcha y soporte continuo.</p>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-10 border-y border-blueprint bg-white/[0.02]\" data-kid=\"62\">\n    <div class=\"max-w-4xl mx-auto text-center\" data-kid=\"63\">\n      <i class=\"ti ti-quote text-5xl text-white/20 mb-10 block\" data-kid=\"64\"></i>\n      <blockquote class=\"font-display text-3xl md:text-4xl font-medium leading-tight tracking-tight mb-12 italic text-white/90\" data-kid=\"65\">\n        \"Triplicamos nuestros contactos desde que lanzamos la nueva web. Y lo mejor, no tuve que aprender nada de programación ni preocuparme por servidores.\"\n      </blockquote>\n      <div class=\"flex items-center justify-center gap-4\" data-kid=\"66\">\n        <div class=\"w-12 h-12 rounded-full border border-blueprint overflow-hidden\" data-kid=\"67\">\n          <img src=\"https://i.pravatar.cc/100?u=ceo\" alt=\"CEO\" class=\"w-full h-full object-cover\" data-kid=\"68\">\n        </div>\n        <div class=\"text-left\" data-kid=\"69\">\n          <p class=\"font-bold text-sm\" data-kid=\"70\">Carlos Mendoza</p>\n          <p class=\"text-xs text-white/40 uppercase tracking-widest\" data-kid=\"71\">Director General, Logística Andina</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"contacto\" class=\"relative py-48 px-10 overflow-hidden\" data-kid=\"72\">\n    \n    <div class=\"absolute inset-0 z-0 opacity-40 cta-video-container\" data-kid=\"73\">\n      <video src=\"https://videos.pexels.com/video-files/8597294/8597294-hd_1280_720_30fps.mp4\" poster=\"https://images.pexels.com/videos/8597294/pexels-photo-8597294.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover\" data-kid=\"74\">\n      </video>\n    </div>\n    \n    <div class=\"max-w-4xl mx-auto text-center relative z-10\" data-kid=\"75\">\n      <h2 class=\"font-display text-6xl md:text-8xl font-extrabold tracking-tighter mb-8\" data-kid=\"76\">HAGÁMOSLO REAL.</h2>\n      <p class=\"text-white/60 text-lg mb-16 max-w-xl mx-auto font-light\" data-kid=\"77\">\n        Cuéntanos tu idea hoy y recibe una propuesta profesional en menos de 24 horas.\n      </p>\n      \n      <div class=\"max-w-md mx-auto\" data-kid=\"78\">\n        <form class=\"space-y-6\" data-kid=\"79\">\n          <input type=\"text\" placeholder=\"Tu Nombre / Empresa\" class=\"w-full bg-transparent border-b border-blueprint py-4 px-2 text-white placeholder:text-white/20 outline-none focus:border-white transition-colors\" data-kid=\"80\">\n          <input type=\"email\" placeholder=\"Correo Electrónico\" class=\"w-full bg-transparent border-b border-blueprint py-4 px-2 text-white placeholder:text-white/20 outline-none focus:border-white transition-colors\" data-kid=\"81\">\n          <button type=\"submit\" class=\"w-full mt-10 px-10 py-6 bg-white text-black font-display font-black text-sm uppercase tracking-widest btn-glow transition-all\" data-kid=\"82\">\n            Solicitar Blueprint Gratuito\n          </button>\n        </form>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-20 px-10 border-t border-blueprint\" data-kid=\"83\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-10\" data-kid=\"84\">\n      <div class=\"flex items-center gap-2 opacity-40\" data-kid=\"85\">\n        <div class=\"w-6 h-6 border border-white flex items-center justify-center font-bold text-[10px]\" data-kid=\"86\">EP</div>\n        <span class=\"font-display font-bold tracking-tighter text-sm uppercase\" data-kid=\"87\">EducaPerú</span>\n      </div>\n      <div class=\"text-[10px] text-white/20 uppercase tracking-[0.4em]\" data-kid=\"88\">\n        © 2026 Todos los derechos reservados\n      </div>\n      <div class=\"flex gap-8 opacity-40\" data-kid=\"89\">\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"90\"><i class=\"ti ti-brand-instagram text-xl\" data-kid=\"91\"></i></a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"92\"><i class=\"ti ti-brand-linkedin text-xl\" data-kid=\"93\"></i></a>\n        <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"94\"><i class=\"ti ti-brand-twitter text-xl\" data-kid=\"95\"></i></a>\n      </div>\n    </div>\n  </footer>\n\n</div>",
