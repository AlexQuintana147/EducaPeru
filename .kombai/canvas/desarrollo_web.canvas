      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    background-color: #000000;\n    color: #ffffff;\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  h1, h2, h3, .font-display {\n    font-family: 'Instrument Sans', sans-serif;\n    letter-spacing: -0.02em;\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(20px);\n    -webkit-backdrop-filter: blur(20px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n  }\n\n  .strongbox-card {\n    background: #000000;\n    border-top: 1px solid rgba(56, 189, 248, 0.4);\n    border-left: 1px solid rgba(255, 255, 255, 0.05);\n    border-right: 1px solid rgba(255, 255, 255, 0.05);\n    border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .strongbox-card:hover {\n    border-top-color: rgba(56, 189, 248, 1);\n    box-shadow: inset 0 20px 40px -20px rgba(56, 189, 248, 0.15);\n    transform: translateY(-4px);\n  }\n\n  .portfolio-img {\n    filter: grayscale(1);\n    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .portfolio-card:hover .portfolio-img {\n    filter: grayscale(0);\n    transform: scale(1.05);\n  }\n\n  .outline-text {\n    color: transparent;\n    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.3);\n  }\n\n  .glow-btn {\n    box-shadow: 0 0 20px rgba(56, 189, 248, 0.2);\n    transition: all 0.3s ease;\n  }\n\n  .glow-btn:hover {\n    box-shadow: 0 0 30px rgba(56, 189, 248, 0.4);\n    transform: translateY(-1px);\n  }\n\n  .form-input {\n    background: transparent;\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.5);\n    transition: all 0.3s ease;\n  }\n\n  .form-input:focus {\n    border-color: #38BDF8;\n    box-shadow: inset 0 0 10px rgba(56, 189, 248, 0.1);\n    outline: none;\n  }\n\n  /* Custom animations */\n  @keyframes float {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-10px); }\n  }\n  .animate-float { animation: float 6s ease-in-out infinite; }\n</style>\n\n<div class=\"relative min-h-screen\" data-kid=\"1\">\n  \n  <nav class=\"fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-10 py-6 glass-card border-none bg-black/40\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-8 h-8 bg-white rounded-sm flex items-center justify-center\" data-kid=\"4\">\n        <span class=\"text-black font-bold\" data-kid=\"5\">E</span>\n      </div>\n      <span class=\"text-xl font-bold tracking-tight\" data-kid=\"6\">EducaPerú</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-white/60\" data-kid=\"7\">\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"8\">Capacitaciones</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"9\">Nosotros</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"10\">Desarrollo Web</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"11\">Contacto</a>\n    </div>\n    <button class=\"px-5 py-2 rounded-full border border-white/10 text-sm font-semibold hover:bg-white hover:text-black transition-all\" data-kid=\"12\">\n      Ingresar\n    </button>\n  </nav>\n\n  \n  <section class=\"relative pt-40 pb-20 px-10 max-w-7xl mx-auto grid md:grid-cols-2 gap-20 items-center\" data-kid=\"13\">\n    <div class=\"z-10\" data-kid=\"14\">\n      <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#38BDF8]/10 border border-[#38BDF8]/20 text-[#38BDF8] text-xs font-bold uppercase tracking-widest mb-6\" data-kid=\"15\">\n        <i class=\"ti ti-sparkles\" data-kid=\"16\"></i> Diseño Web Premium\n      </div>\n      <h1 class=\"text-5xl lg:text-7xl font-bold leading-[1.1] mb-8\" data-kid=\"17\">\n        Transformamos tu visión en una <span class=\"text-[#38BDF8]\" data-kid=\"18\">experiencia</span> digital impecable.\n      </h1>\n      <p class=\"text-lg text-slate-400 max-w-lg mb-10 leading-relaxed\" data-kid=\"19\">\n        Olvídate de servidores, códigos y complicaciones. Nosotros construimos la herramienta, tú la usas para vender más.\n      </p>\n      <div class=\"flex items-center gap-4\" data-kid=\"20\">\n        <button class=\"px-8 py-4 rounded-full bg-white text-black font-bold text-base glow-btn\" data-kid=\"21\">\n          Solicitar cotización\n        </button>\n        <button class=\"px-8 py-4 rounded-full border border-white/10 text-white font-bold text-base hover:bg-white/5 transition-colors\" data-kid=\"22\">\n          Ver Proyectos\n        </button>\n      </div>\n    </div>\n    <div class=\"relative flex justify-center items-center\" data-kid=\"23\">\n      <div class=\"absolute inset-0 bg-radial-[at_50%_50%,_rgba(56,189,248,0.1)_0%,_transparent_70%]\" data-kid=\"24\"></div>\n      <video src=\"https://videos.pexels.com/video-files/35626375/15097606_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/35626375/pexels-photo-35626375.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full max-w-md rounded-3xl mix-blend-lighten animate-float\" data-kid=\"25\"></video>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-10 bg-black\" data-kid=\"26\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"27\">\n      <div class=\"grid md:grid-cols-2 gap-32 items-start mb-24\" data-kid=\"28\">\n        <div data-kid=\"29\">\n          <h2 class=\"text-4xl lg:text-5xl font-bold mb-6\" data-kid=\"30\">Ingeniería de clase mundial para tu negocio.</h2>\n          <p class=\"text-slate-400 text-lg\" data-kid=\"31\">Diseñamos cada detalle pensando en la conversión y la estabilidad.</p>\n        </div>\n        <div class=\"grid grid-cols-2 gap-6\" data-kid=\"32\">\n          <div class=\"strongbox-card p-10 rounded-2xl flex flex-col items-center text-center\" data-kid=\"33\">\n            <div class=\"w-12 h-12 mb-6 flex items-center justify-center text-[#38BDF8]\" data-kid=\"34\">\n              <i class=\"ti ti-bolt text-3xl\" data-kid=\"35\"></i>\n            </div>\n            <h3 class=\"font-bold text-lg mb-2\" data-kid=\"36\">Carga Ultrarrápida</h3>\n            <p class=\"text-sm text-slate-500\" data-kid=\"37\">Optimizado para Core Web Vitals.</p>\n          </div>\n          <div class=\"strongbox-card p-10 rounded-2xl flex flex-col items-center text-center\" data-kid=\"38\">\n            <div class=\"w-12 h-12 mb-6 flex items-center justify-center text-[#38BDF8]\" data-kid=\"39\">\n              <i class=\"ti ti-pencil text-3xl\" data-kid=\"40\"></i>\n            </div>\n            <h3 class=\"font-bold text-lg mb-2\" data-kid=\"41\">Diseño a Medida</h3>\n            <p class=\"text-sm text-slate-500\" data-kid=\"42\">Identidad visual única y premium.</p>\n          </div>\n          <div class=\"strongbox-card p-10 rounded-2xl flex flex-col items-center text-center\" data-kid=\"43\">\n            <div class=\"w-12 h-12 mb-6 flex items-center justify-center text-[#38BDF8]\" data-kid=\"44\">\n              <i class=\"ti ti-lifebuoy text-3xl\" data-kid=\"45\"></i>\n            </div>\n            <h3 class=\"font-bold text-lg mb-2\" data-kid=\"46\">Soporte Continuo</h3>\n            <p class=\"text-sm text-slate-500\" data-kid=\"47\">Estamos contigo en cada paso.</p>\n          </div>\n          <div class=\"strongbox-card p-10 rounded-2xl flex flex-col items-center text-center\" data-kid=\"48\">\n            <div class=\"w-12 h-12 mb-6 flex items-center justify-center text-[#38BDF8]\" data-kid=\"49\">\n              <i class=\"ti ti-search text-3xl\" data-kid=\"50\"></i>\n            </div>\n            <h3 class=\"font-bold text-lg mb-2\" data-kid=\"51\">SEO Integrado</h3>\n            <p class=\"text-sm text-slate-500\" data-kid=\"52\">Aparece en los primeros resultados.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-10 bg-black overflow-hidden\" data-kid=\"53\">\n    <div class=\"max-w-7xl mx-auto\" data-kid=\"54\">\n      <div class=\"mb-20\" data-kid=\"55\">\n        <span class=\"text-[#38BDF8] font-bold text-sm tracking-widest uppercase mb-4 block\" data-kid=\"56\">Portafolio Seleccionado</span>\n        <h2 class=\"text-5xl font-bold\" data-kid=\"57\">Historias de éxito digital.</h2>\n      </div>\n      \n      <div class=\"flex flex-col md:flex-row gap-10\" data-kid=\"58\">\n        <div class=\"portfolio-card relative flex-1 group overflow-hidden rounded-3xl h-[600px]\" data-kid=\"59\">\n          <img src=\"https://images.unsplash.com/photo-1712002641157-02b4f7a030aa?auto=format&w=800&q=80&fit=crop\" alt=\"Mobile Project\" class=\"portfolio-img absolute inset-0 w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"60\">\n          <div class=\"absolute inset-0 bg-linear-to-t from-black via-transparent to-transparent opacity-80\" data-kid=\"61\"></div>\n          <div class=\"absolute bottom-10 left-10 translate-y-4 group-hover:translate-y-0 transition-all duration-500 opacity-0 group-hover:opacity-100\" data-kid=\"62\">\n            <h4 class=\"text-2xl font-bold mb-2\" data-kid=\"63\">Luxury Mobile Experience</h4>\n            <p class=\"text-white/60\" data-kid=\"64\">E-commerce de alto rendimiento.</p>\n          </div>\n        </div>\n        <div class=\"portfolio-card relative flex-1 group overflow-hidden rounded-3xl h-[600px] mt-20\" data-kid=\"65\">\n          <img src=\"https://images.unsplash.com/photo-1589178208772-6f239b7652e9?auto=format&w=800&q=80&fit=crop\" alt=\"Desktop Project\" class=\"portfolio-img absolute inset-0 w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"66\">\n          <div class=\"absolute inset-0 bg-linear-to-t from-black via-transparent to-transparent opacity-80\" data-kid=\"67\"></div>\n          <div class=\"absolute bottom-10 left-10 translate-y-4 group-hover:translate-y-0 transition-all duration-500 opacity-0 group-hover:opacity-100\" data-kid=\"68\">\n            <h4 class=\"text-2xl font-bold mb-2\" data-kid=\"69\">Corporate Ecosystem</h4>\n            <p class=\"text-white/60\" data-kid=\"70\">Arquitectura de información robusta.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-40 px-10 bg-black text-center border-y border-white/5\" data-kid=\"71\">\n    <div class=\"max-w-5xl mx-auto\" data-kid=\"72\">\n      <h2 class=\"outline-text text-6xl md:text-8xl font-black mb-10 leading-none\" data-kid=\"73\">\n        TU TRANQUILIDAD ES NUESTRA PRIORIDAD.\n      </h2>\n      <p class=\"text-2xl text-slate-400 font-medium\" data-kid=\"74\">Entregamos a tiempo, sin costos ocultos.</p>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 px-10 bg-black\" data-kid=\"75\">\n    <div class=\"max-w-3xl mx-auto text-center\" data-kid=\"76\">\n      <h2 class=\"text-4xl font-bold mb-4\" data-kid=\"77\">¿Hablamos de tu próximo paso?</h2>\n      <p class=\"text-slate-400 mb-16 text-lg\" data-kid=\"78\">Cuéntanos sobre tu empresa y nos encargamos de todo el proceso técnico.</p>\n      \n      <form class=\"space-y-6 text-left\" data-kid=\"79\">\n        <div class=\"grid md:grid-cols-2 gap-6\" data-kid=\"80\">\n          <div class=\"space-y-2\" data-kid=\"81\">\n            <label class=\"text-xs font-bold text-white/40 uppercase tracking-widest ml-1\" data-kid=\"82\">Tu Nombre</label>\n            <input type=\"text\" placeholder=\"Ej. Alex Pérez\" class=\"form-input w-full p-4 rounded-xl text-white\" data-kid=\"83\">\n          </div>\n          <div class=\"space-y-2\" data-kid=\"84\">\n            <label class=\"text-xs font-bold text-white/40 uppercase tracking-widest ml-1\" data-kid=\"85\">Correo Electrónico</label>\n            <input type=\"email\" placeholder=\"alex@empresa.com\" class=\"form-input w-full p-4 rounded-xl text-white\" data-kid=\"86\">\n          </div>\n        </div>\n        <div class=\"space-y-2\" data-kid=\"87\">\n          <label class=\"text-xs font-bold text-white/40 uppercase tracking-widest ml-1\" data-kid=\"88\">Sobre tu empresa</label>\n          <textarea rows=\"4\" placeholder=\"Háblanos de tus objetivos...\" class=\"form-input w-full p-4 rounded-xl text-white resize-none\" data-kid=\"89\"></textarea>\n        </div>\n        <button class=\"w-full py-5 rounded-xl bg-[#38BDF8] text-black font-black text-lg glow-btn\" data-kid=\"90\">\n          Enviar Propuesta\n        </button>\n      </form>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-20 px-10 border-t border-white/5 text-center\" data-kid=\"91\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-10\" data-kid=\"92\">\n      <div class=\"flex items-center gap-2\" data-kid=\"93\">\n        <div class=\"w-8 h-8 bg-white/10 rounded-sm flex items-center justify-center\" data-kid=\"94\">\n          <span class=\"text-white font-bold\" data-kid=\"95\">E</span>\n        </div>\n        <span class=\"text-lg font-bold\" data-kid=\"96\">EducaPerú</span>\n      </div>\n      <p class=\"text-slate-500 text-sm\" data-kid=\"97\">© 2026 Centro de Capacitación y Consultoría Empresarial EDUCA PERÚ S.A.C.</p>\n      <div class=\"flex items-center gap-6\" data-kid=\"98\">\n        <a href=\"#\" class=\"text-slate-400 hover:text-white transition-colors\" data-kid=\"99\"><i class=\"ti ti-brand-facebook text-xl\" data-kid=\"100\"></i></a>\n        <a href=\"#\" class=\"text-slate-400 hover:text-white transition-colors\" data-kid=\"101\"><i class=\"ti ti-brand-instagram text-xl\" data-kid=\"102\"></i></a>\n        <a href=\"